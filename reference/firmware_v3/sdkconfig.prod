# NovaPanel firmware - production security overrides.
#
# Apply on top of sdkconfig.defaults with:
#   idf.py -DSDKCONFIG_DEFAULTS="sdkconfig.defaults;sdkconfig.prod" build
#
# DEV builds use only sdkconfig.defaults so flashing/debugging stays frictionless.
#
# Key generation (do once, store outside the repo):
#   espsecure.py generate_signing_key --version 2 secure_boot_signing_key.pem
#
# Flash Encryption RELEASE mode is irreversible on each unit. Use this profile
# only for production provisioning after the bench firmware path is validated.

# ----- Secure Boot v2 -----
CONFIG_SECURE_BOOT=y
CONFIG_SECURE_BOOT_V2_ENABLED=y
CONFIG_SECURE_BOOT_SIGNING_KEY="secure_boot_signing_key.pem"
CONFIG_SECURE_BOOT_INSECURE=n
CONFIG_BOOTLOADER_APP_ANTI_ROLLBACK=y
CONFIG_BOOTLOADER_APP_ANTI_ROLLBACK_SECURITY_VERSION=1

# ----- Flash Encryption (RELEASE mode) -----
CONFIG_SECURE_FLASH_ENC_ENABLED=y
CONFIG_SECURE_FLASH_ENC_MODE_RELEASE=y

# ----- NVS Encryption -----
CONFIG_NVS_ENCRYPTION=y

# ----- Production privacy/hardening -----
CONFIG_ESP_COREDUMP_ENABLE_TO_FLASH=n
CONFIG_LOG_DEFAULT_LEVEL_WARN=y
CONFIG_LOG_DEFAULT_LEVEL=2
